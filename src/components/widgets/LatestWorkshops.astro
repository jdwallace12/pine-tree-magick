---
import { getCollection } from 'astro:content';
import { twMerge } from 'tailwind-merge';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';

const {
  title = 'Upcoming Workshops',
  subtitle = 'Join our transformative learning experiences',
  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render('bg'),
} = Astro.props;

const workshops = await getCollection('workshop');

// Filter workshops to exclude past events
const filteredWorkshops = workshops.filter((workshop) => {
  const workshopDate = new Date(workshop.data.date);
  const currentDate = new Date();
  return workshopDate >= currentDate;
});

const getColumnClass = (totalItems) => {
  if (totalItems === 1) return 'w-full md:w-2/3 lg:w-2/3';
  if (totalItems === 2 || totalItems === 4) return 'w-full md:w-[calc(50%-3rem)]';
  return 'w-full md:w-[calc(50%-3rem)] lg:w-[calc(33.33%-4rem)]';
};

// Sort the filtered workshops by date
const sortedWorkshops = filteredWorkshops.sort(
  (a, b) => new Date(a.data.date).valueOf() - new Date(b.data.date).valueOf()
);
---

{
  sortedWorkshops.length > 0 && (
    <WidgetWrapper id={id} isDark={isDark} containerClass={twMerge('pb-4 md:pb-6 lg:pb-8', classes?.container)} bg={bg}>
      <Headline title={title} subtitle={subtitle} />
      <div class={`flex flex-wrap gap-12 row-gap-5 lg:gap-14 mb-4 mx-auto max-w-7xl px-2 md:px-12 justify-center`}>
        {sortedWorkshops.map((workshop) => {
          const slug = workshop.data.slug || workshop.id.replace(/\.md$/, '');
          return (
            <div
              class={`relative flex flex-col ${getColumnClass(sortedWorkshops.length)} dark:border-slate-600 dark:border overflow-hidden rounded-md shadow-md dark:hover:border-1 dark:hover:border-primary transition-all duration-300`}
            >
              <a
                href={`/workshops/${slug}`}
                class="block group workshop-card"
                data-workshop-slug={slug}
                data-max-participants={workshop.data.maxParticipants || ''}
              >
                <div class="overflow-hidden relative">
                  <img
                    src={workshop.data.image}
                    alt={workshop.data.title}
                    class={twMerge(
                      'w-full flex object-cover transform transition-transform duration-300 group-hover:scale-110',
                      sortedWorkshops.length === 1 ? 'h-64 md:h-80' : 'h-48'
                    )}
                  />
                  {/* Static or Dynamic Sold Out Badge */}
                  {(workshop.data.soldOut || workshop.data.maxParticipants) && (
                    <div
                      class={`absolute top-2 right-2 bg-red-600 text-white px-2 py-1 rounded text-xs font-bold uppercase tracking-wider shadow-md sold-out-badge ${!workshop.data.soldOut ? 'hidden' : ''}`}
                    >
                      Sold Out
                    </div>
                  )}
                </div>
                <div class="px-4 py-6 overflow-hidden">
                  <h3 class="text-xl font-bold mb-2 group-hover:text-primary transition-colors">
                    {workshop.data.title}
                  </h3>
                  <span class="text-gray-600 dark:text-gray-400">{workshop.data.date}</span>
                  <p class="text-gray-600 dark:text-gray-400 text-sm mb-4">{workshop.data.excerpt}</p>
                  <div class="flex justify-between items-center text-sm">
                    <div class="text-sm text-gray-600 dark:text-muted flex flex-col">
                      <span>{workshop.data.location}</span>
                      {workshop.data.maxParticipants && (
                        <span class="text-xs text-primary font-semibold mt-1 spots-remaining-text hidden">
                          Loading spots...
                        </span>
                      )}
                    </div>
                    <span class="bg-blue-100 dark:bg-primary dark:text-dark px-2 py-1 rounded font-bold h-fit">
                      ${workshop.data.price}
                    </span>
                  </div>
                </div>
              </a>
            </div>
          );
        })}
      </div>
    </WidgetWrapper>
  )
}

<script>
  // Fetch live spots for each workshop card on the page
  const updateWorkshopCards = async () => {
    const cards = document.querySelectorAll('.workshop-card');

    cards.forEach(async (card) => {
      const slug = card.getAttribute('data-workshop-slug');
      const maxParticipantsStr = card.getAttribute('data-max-participants');

      if (!slug || !maxParticipantsStr) return; // Only process workshops with limits

      const maxParticipants = parseInt(maxParticipantsStr, 10);
      const spotsText = card.querySelector('.spots-remaining-text');
      const soldOutBadge = card.querySelector('.sold-out-badge');

      try {
        const res = await fetch(`/.netlify/functions/workshop-spots?workshop=${slug}`);
        if (!res.ok) throw new Error('Failed to fetch spots');

        const data = await res.json();
        const spotsRemaining = data.spotsRemaining ?? maxParticipants;
        const isSoldOut = data.soldOut ?? false;

        if (isSoldOut) {
          if (soldOutBadge) soldOutBadge.classList.remove('hidden');
          if (spotsText) Object.assign(spotsText.style, { display: 'none' });
        } else {
          if (spotsText) {
            spotsText.textContent = `${spotsRemaining} ${spotsRemaining === 1 ? 'spot' : 'spots'} left`;
            spotsText.classList.remove('hidden');
          }
        }
      } catch (error) {
        console.error(`Error fetching spots for ${slug}:`, error);
        if (spotsText) spotsText.classList.add('hidden'); // Hide on error
      }
    });
  };

  // Run on page load and on Astro view transitions
  document.addEventListener('DOMContentLoaded', updateWorkshopCards);
  document.addEventListener('astro:page-load', updateWorkshopCards);
</script>
