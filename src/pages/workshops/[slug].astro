---
import { getCollection } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';
import PurchaseForm from '~/components/PurchaseForm.astro';

export async function getStaticPaths() {
  const workshops = await getCollection('workshop');
  return workshops.map((workshop) => ({
    // @ts-ignore
    params: { slug: workshop.data.slug || workshop.id.replace(/\.md$/, '') || 'default-slug' },
  }));
}

const { slug } = Astro.params as { slug: string };
const workshops = await getCollection('workshop');
// @ts-ignore

const workshop = workshops.find((workshop) => (workshop.data.slug || workshop.id.replace(/\.md$/, '')) === slug);

if (!workshop) {
  throw new Error('Workshop not found');
}

const {
  title,
  description,
  image,
  price,
  date,
  time,
  location,
  signupLink,
  payPalButtonId,
  isPaid,
  showAllergies,
  soldOut,
  maxParticipants,
  slug: workshopSlug,
} = workshop.data;
const body = workshop.body;
const { Content } = await workshop.render();

const metadata = {
  title: title,
  description: description,
};

const hasPurchase = (payPalButtonId || isPaid) && !soldOut;
---

<Layout metadata={metadata}>
  <article
    class="max-w-2xl mx-auto p-6 space-y-6"
    id="workshop-article"
    data-workshop-slug={workshopSlug || slug}
    data-max-participants={maxParticipants}
  >
    <div class="flex justify-between items-center sticky top-[4.5rem] bg-dark py-4 z-10">
      <a href="/workshops#workshops" class="flex underline w-max"
        ><Icon name="tabler:arrow-left" class="w-5 h-5 mr-1" />Back to All Workshops</a
      >
      {
        signupLink && !soldOut && (
          <a class="btn-primary ml-2 py-2.5 px-5.5 md:px-6 font-semibold shadow-none text-sm w-auto" href={signupLink}>
            Sign Up
          </a>
        )
      }
      {
        hasPurchase && (
          <a class="btn-primary ml-2 py-2.5 px-5.5 md:px-6 font-semibold shadow-none text-sm w-auto" href="#purchase">
            Register Now
          </a>
        )
      }
    </div>
    <div class="relative">
      <img src={image} alt={title} class="w-full h-64 object-cover rounded-lg shadow-md" />
      <div
        id="dynamic-image-badge"
        class={`absolute top-4 right-4 bg-red-600 text-white px-4 py-2 rounded-md font-bold shadow-lg transform rotate-3 uppercase tracking-wider border-2 border-white ${soldOut ? '' : 'hidden'}`}
      >
        Sold Out
      </div>
    </div>
    <h1 class="text-4xl mt-4 font-heading">{title}</h1>
    <div class="text-lg">
      <p><strong>Date:</strong> {date}</p>
      <p><strong>Time:</strong> {time}</p>
      <p><strong>Location:</strong> {location}</p>
      <p><strong>Price:</strong> ${price}</p>
      <p>
        <strong>Spots Remaining:</strong>
        <span class="spots-remaining" style="visibility: hidden;">{maxParticipants}</span>
      </p>
    </div>
    <div>
      <div
        class="prose prose-lg prose-headings:text-primary prose-headings:font-heading prose-p:text-muted prose-li:text-muted prose-strong:text-heading prose-strong:font-semibold dark:prose-invert max-w-none"
      >
        <Content />
        {
          signupLink && !soldOut && (
            <a
              class="btn-primary py-2.5 px-5.5 md:px-6 font-semibold shadow-none no-underline text-sm w-36 block mx-auto mt-8"
              href={signupLink}
              target="_blank"
            >
              Sign Up
            </a>
          )
        }
      </div>
    </div>

    {/* Sold Out Banner */}
    <div
      id="dynamic-sold-out"
      class={`mt-12 p-8 border-2 border-dashed border-gray-300 dark:border-slate-700 rounded-lg text-center ${soldOut ? '' : 'hidden'}`}
    >
      <h2 class="text-3xl font-heading mb-4">Sold Out</h2>
      <p class="text-muted text-lg">
        This workshop is currently sold out. Follow me on social media or check back later for future dates!
      </p>
    </div>

    {
      hasPurchase && payPalButtonId && !soldOut && (
        <div id="purchase-wrapper" class="mt-12">
          {/* Dynamic spots counter — hidden until JS loads the count */}
          {maxParticipants && (
            <div
              id="spots-counter"
              class="hidden bg-primary/10 rounded-lg p-4 text-center mb-0"
              data-workshop-slug={workshopSlug || slug}
              data-max-participants={maxParticipants}
            >
              <h3 class="text-2xl text-primary font-heading">
                <span class="spots-remaining">{maxParticipants}</span> spots left
              </h3>
            </div>
          )}
          <h2 class="text-3xl font-heading text-center mb-4">Reserve Your Spot</h2>
          <p class="text-center text-muted mb-8">
            Register below to secure your place in this workshop. After submission, you'll be redirected to PayPal to
            complete your purchase.
          </p>
          <PurchaseForm
            title={title}
            payPalButtonId={payPalButtonId}
            formName="workshops"
            itemType="Workshop"
            showAllergies={showAllergies}
          />
        </div>
      )
    }
  </article>
</Layout>

<script>
  function initSpotsCounter() {
    const articleEl = document.getElementById('workshop-article');
    if (!articleEl) return;

    const workshopSlug = articleEl.dataset.workshopSlug;
    // maxParticipants could be undefined if there's no limit
    if (!workshopSlug || !articleEl.dataset.maxParticipants) return;

    const maxParticipants = parseInt(articleEl.dataset.maxParticipants, 10);

    fetch(`/.netlify/functions/workshop-spots?workshop=${workshopSlug}`)
      .then((res) => {
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        return res.json();
      })
      .then((data) => {
        const spotsRemaining = data.spotsRemaining ?? maxParticipants;
        const soldOut = data.soldOut ?? false;
        const filledPercent = Math.round(((maxParticipants - spotsRemaining) / maxParticipants) * 100);

        // Update all spots-remaining elements
        document.querySelectorAll('.spots-remaining').forEach((el) => {
          // If the element's parent text includes "left" or "remaining", we just update the number.
          // The spans themselves only contain the number currently.
          el.textContent = spotsRemaining;

          // Let's also update the text node *after* the span to handle pluralization
          if (el.nextSibling && el.nextSibling.nodeType === Node.TEXT_NODE) {
            const node = el.nextSibling as Text;
            const text = node.textContent;
            if (text && text.includes('spot left')) {
              node.textContent = text.replace(/spots? left/, spotsRemaining === 1 ? 'spot left' : 'spots left');
            } else if (text && text.includes('spots left')) {
              node.textContent = text.replace(/spots? left/, spotsRemaining === 1 ? 'spot left' : 'spots left');
            } else if (text && text.includes('spot remaining')) {
              node.textContent = text.replace(
                /spots? remaining/,
                spotsRemaining === 1 ? 'spot remaining' : 'spots remaining'
              );
            } else if (text && text.includes('spots remaining')) {
              node.textContent = text.replace(
                /spots? remaining/,
                spotsRemaining === 1 ? 'spot remaining' : 'spots remaining'
              );
            }
          }

          // Reveal the number now that we have the real count
          (el as HTMLElement).style.visibility = 'visible';
        });

        const counterEl = document.getElementById('spots-counter');

        // Show the counter only if 5 or fewer spots remain
        if (spotsRemaining <= 5) {
          if (counterEl) counterEl.classList.remove('hidden');
        } else {
          if (counterEl) counterEl.classList.add('hidden');
        }

        // Handle sold-out state
        if (soldOut) {
          // Hide the registration section
          const purchaseWrapper = document.getElementById('purchase-wrapper');
          if (purchaseWrapper) purchaseWrapper.classList.add('hidden');

          // Hide the "Register Now" sticky button
          const registerBtns = document.querySelectorAll('a[href="#purchase-wrapper"], a[href="#purchase"]');
          registerBtns.forEach((btn) => btn.classList.add('hidden'));

          // Hide the inline sign-up link
          const signupBtns = document.querySelectorAll('a.btn-primary');
          signupBtns.forEach((btn) => {
            if (btn.textContent.trim() === 'Sign Up') btn.classList.add('hidden');
          });

          // Show the dynamic sold-out banners
          const dynamicSoldOut = document.getElementById('dynamic-sold-out');
          if (dynamicSoldOut) dynamicSoldOut.classList.remove('hidden');

          const dynamicImageBadge = document.getElementById('dynamic-image-badge');
          if (dynamicImageBadge) dynamicImageBadge.classList.remove('hidden');

          // Update counter styling for sold-out
          if (counterEl) {
            counterEl.classList.remove('bg-primary/10', 'border-primary/30');
            counterEl.classList.add('bg-red-500/10', 'border-red-500/30');
          }
        }
      })
      .catch((err) => {
        console.warn('Could not load workshop spots:', err);
        // On error, still show the counter with the static max value
        const counterEl = document.getElementById('spots-counter');
        if (counterEl) counterEl.classList.remove('hidden');
      });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSpotsCounter);
  } else {
    initSpotsCounter();
  }
</script>
