---
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';
import { getCollection, getEntry } from 'astro:content';
import { YouTube } from 'astro-embed';
import Quiz from '~/components/widgets/Quiz.astro';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  lesson: CollectionEntry<'lesson'>;
  nextLesson: {
    slug: string;
    title: string;
  } | null;
  previousLesson: {
    slug: string;
    title: string;
  } | null;
}

export async function getStaticPaths() {
  const lessons = await getCollection('lesson');
  const courses = await getCollection('course', ({ data }) => data.published === true);

  // Group lessons by course
  const courseLessonsMap = lessons.reduce(
    (acc, lesson) => {
      const courseSlug = lesson.data.course;
      if (!acc[courseSlug]) acc[courseSlug] = [];
      acc[courseSlug].push(lesson);
      return acc;
    },
    {} as Record<string, typeof lessons>
  );

  const paths: any[] = [];

  for (const courseSlug in courseLessonsMap) {
    const course = courses.find((c) => c.slug === courseSlug);
    const courseLessons = courseLessonsMap[courseSlug];

    if (!course) continue;

    // Sort lessons based on module order and lesson order within module
    const modules = course.data.modules || [];
    const sortedLessons = [...courseLessons].sort((a, b) => {
      const moduleAIndex = modules.indexOf(a.data.module);
      const moduleBIndex = modules.indexOf(b.data.module);

      if (moduleAIndex !== moduleBIndex) {
        return moduleAIndex - moduleBIndex;
      }
      return a.data.order - b.data.order;
    });

    // Create paths for each lesson with its next lesson info
    for (let i = 0; i < sortedLessons.length; i++) {
      const lesson = sortedLessons[i];
      const previousLesson = i > 0 ? sortedLessons[i - 1] : null;
      const nextLesson = i < sortedLessons.length - 1 ? sortedLessons[i + 1] : null;

      paths.push({
        params: {
          slug: courseSlug,
          lesson: lesson.slug.split('/').pop(),
        },
        props: {
          lesson,
          nextLesson: nextLesson
            ? {
                slug: nextLesson.slug.split('/').pop() as string,
                title: nextLesson.data.title,
              }
            : null,
          previousLesson: previousLesson
            ? {
                slug: previousLesson.slug.split('/').pop() as string,
                title: previousLesson.data.title,
              }
            : null,
        },
      });
    }
  }

  return paths;
}

const { lesson, nextLesson, previousLesson } = Astro.props;
const { Content } = await lesson.render();
const course = await getEntry('course', lesson.data.course);

const metadata = {
  title: `${lesson.data.title} | ${course?.data.title}`,
  robots: {
    index: false,
    follow: false,
  },
};

const requiredRole = `course:${course?.slug}`;
---

<Layout metadata={metadata}>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <!-- Breadcrumbs -->
    <nav class="text-sm mb-8 text-muted">
      <a href="/shop#courses" class="hover:text-primary">Courses</a>
      <span class="mx-2">/</span>
      <a href={`/courses/${course?.slug}`} class="hover:text-primary">{course?.data.title}</a>
      <span class="mx-2">/</span>
      <span class="font-medium text-default">{lesson.data.title}</span>
    </nav>

    <div id="lesson-content" data-required-role={lesson.data.isFree ? '' : requiredRole}>
      <h1 class="text-3xl font-heading font-bold mb-4">{lesson.data.title}</h1>
      <p class="text-muted mb-8">{lesson.data.module}</p>

      <div
        class="mt-12 prose prose-lg leading-relaxed tracking-wide dark:prose-invert dark:text-slate-300 max-w-none prose-table:bg-[#0f172a] prose-table:text-slate-300 prose-th:text-slate-200 prose-td:text-slate-300 lesson-content"
      >
        <Content />
      </div>

      {
        lesson.data.quiz && lesson.data.quiz.length > 0 && (
          <div class="mt-16 w-[100vw] relative left-1/2 -translate-x-1/2 border-y border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900/50 py-16 px-4 sm:px-6 lg:px-8 overflow-hidden">
            <h3 class="text-3xl font-heading font-bold mb-12 text-center">Knowledge Check</h3>
            <div class="max-w-7xl mx-auto">
              <Quiz
                title=""
                questions={lesson.data.quiz}
                showScore={lesson.data.allowScore ?? false}
                hideFeedback={lesson.data.hideFeedback ?? false}
              />
            </div>
          </div>
        )
      }

      <!-- Lesson Navigation/Completion Container -->
      <div
        class="mt-16 pt-8 border-t border-slate-200 dark:border-slate-700 flex flex-col sm:flex-row items-center justify-center gap-4"
      >
        {
          previousLesson && (
            <a
              href={`/courses/${course?.slug}/${previousLesson.slug}`}
              class="flex items-center gap-2 px-8 py-3 bg-white dark:bg-slate-900 border-2 border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-300 rounded-full font-bold transition-all duration-300 hover:border-primary w-full sm:w-auto justify-center"
            >
              <Icon name="tabler:arrow-left" class="w-5 h-5" />
              Previous
            </a>
          )
        }

        <button
          id="mark-complete-btn"
          data-course-slug={course?.slug}
          data-lesson-slug={lesson.slug.split('/').pop()}
          class="flex items-center gap-2 px-8 py-3 rounded-full font-bold transition-all duration-300 border-2 w-full sm:w-auto justify-center"
        >
          <span class="icon-pending italic">Mark as Completed</span>
          <span class="icon-completed hidden items-center gap-2"
            >Completed <Icon name="tabler:circle-check" class="w-5 h-5" /></span
          >
        </button>

        {
          nextLesson && (
            <a
              id="next-lesson-btn"
              href={`/courses/${course?.slug}/${nextLesson.slug}`}
              class="flex items-center gap-2 px-8 py-3 bg-slate-900 dark:bg-slate-100 text-white dark:text-black rounded-full font-bold transition-all duration-300 hover:bg-slate-800 dark:hover:bg-white border-2 border-transparent w-full sm:w-auto justify-center"
            >
              Next Lesson
              <Icon name="tabler:arrow-right" class="w-5 h-5" />
            </a>
          )
        }
      </div>

      {
        lesson.data.pdfUrl && (
          <div class="mt-12 p-6 bg-slate-50 dark:bg-slate-800 rounded-lg border border-slate-200 dark:border-slate-700">
            <h3 class="text-xl font-heading font-bold mb-4 flex items-center">
              <span class="mr-2">📄</span> Resources
            </h3>
            <a href={lesson.data.pdfUrl} target="_blank" class="text-primary hover:underline flex items-center">
              Download PDF Material
            </a>
          </div>
        )
      }
    </div>
  </div>

  <script>
    import { getCompletedLessons, markLessonComplete, markLessonIncomplete } from '~/utils/progress';

    function initProgress() {
      const btn = document.getElementById('mark-complete-btn');
      if (!btn) return;

      const courseSlug = btn.dataset.courseSlug;
      const lessonSlug = btn.dataset.lessonSlug;
      if (!courseSlug || !lessonSlug) return;

      const updateBtnUI = (isCompleted: boolean) => {
        const pending = btn.querySelector('.icon-pending');
        const completed = btn.querySelector('.icon-completed');

        if (isCompleted) {
          btn.classList.add('bg-green-100', 'text-green-800', 'border-green-200');
          btn.classList.remove(
            'bg-white',
            'dark:bg-slate-900',
            'border-slate-200',
            'dark:border-slate-700',
            'hover:border-primary'
          );
          if (pending) pending.classList.add('hidden');
          if (completed) {
            completed.classList.remove('hidden');
            completed.classList.add('flex');
          }
        } else {
          btn.classList.remove('bg-green-100', 'text-green-800', 'border-green-200');
          btn.classList.add(
            'bg-white',
            'dark:bg-slate-900',
            'border-slate-200',
            'dark:border-slate-700',
            'hover:border-primary'
          );
          if (pending) pending.classList.remove('hidden');
          if (completed) {
            completed.classList.add('hidden');
            completed.classList.remove('flex');
          }
        }
      };

      // Initial state
      const completedLessons = getCompletedLessons(courseSlug);
      let isCompleted = completedLessons.includes(lessonSlug);
      updateBtnUI(isCompleted);

      // Click handler for Mark Complete
      btn.onclick = async () => {
        isCompleted = !isCompleted;
        updateBtnUI(isCompleted);

        if (isCompleted) {
          await markLessonComplete(courseSlug, lessonSlug);
        } else {
          await markLessonIncomplete(courseSlug, lessonSlug);
        }
      };

      // Click handler for Next Lesson (Auto-complete)
      const nextBtn = document.getElementById('next-lesson-btn');
      if (nextBtn) {
        nextBtn.onclick = async (e) => {
          e.preventDefault();
          // Always mark as complete when clicking Next Lesson
          if (!isCompleted) {
            isCompleted = true;
            updateBtnUI(true);
            await markLessonComplete(courseSlug, lessonSlug);
          }
          window.location.href = (nextBtn as HTMLAnchorElement).href;
        };
      }
    }

    // Run on load and on Astro events
    initProgress();
    window.initProgress = initProgress;
    document.addEventListener('astro:page-load', initProgress);
  </script>

  <style is:global>
    .lesson-content .table-wrapper {
      padding: 24px;
      background-color: #0f172a;
      border-radius: 12px;
      margin: 24px 0;
      overflow: auto;
    }
    .lesson-content table {
      background-color: transparent;
      border-color: #334155;
      width: 100%;
      margin: 0;
    }
    .lesson-content th {
      background-color: transparent;
      color: #e2e8f0;
      border-color: #334155;
      padding: 12px 16px;
    }
    .lesson-content td {
      color: #cbd5e1;
      border-color: #334155;
      padding: 12px 16px;
      background-color: transparent;
    }
    .lesson-content pre {
      background-color: #0f172a !important;
    }
    .lesson-content .lesson-figure {
      margin: 64px 0;
      text-align: center;
    }
    .lesson-content .lesson-figure img {
      border-radius: 12px;
      max-width: 100%;
      display: block;
      margin: 0 auto;
    }
    .lesson-content .lesson-figure figcaption {
      margin-top: 10px;
      font-size: 0.85rem;
      color: #94a3b8;
      font-style: italic;
      letter-spacing: 0.02em;
    }
  </style>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Identity Event Listeners for progress syncing (if they log in/out while on a free page)
      if (window.netlifyIdentity && !window.__lessonListenersAdded) {
        const runGlobalCheck = () => {
          if (typeof window.initProgress === 'function') window.initProgress();
        };

        window.netlifyIdentity.on('init', runGlobalCheck);
        window.netlifyIdentity.on('login', runGlobalCheck);
        window.netlifyIdentity.on('logout', runGlobalCheck);

        window.__lessonListenersAdded = true;
      }
    });
  </script>
</Layout>
