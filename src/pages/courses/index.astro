---
import Layout from '~/layouts/PageLayout.astro';
import Features2 from '~/components/widgets/Features2.astro';
import { getCollection } from 'astro:content';

const metadata = {
  title: 'Courses | Pine Tree Magick',
};

const courses = await getCollection('course');
const allLessons = await getCollection('lesson');

const items = await Promise.all(
  courses.map(async (course) => {
    const courseLessons = allLessons.filter((l) => l.data.course === course.slug);
    return {
      title: course.data.title,
      description: course.data.description,
      icon: 'tabler:book',
      callToAction: {
        text: 'View Course',
        href: `/courses/${course.slug}`,
      },
      image: { src: course.data.image, alt: course.data.title },
      classes: {
        panel: `course-card-${course.slug}`,
      },
      // We'll store lesson count in a data attribute by wrapping or finding it
      // ItemGrid2 allows data attributes if we are lucky, but let's use a simpler way
      // We'll add a hidden element with the data
      lessonCount: courseLessons.length,
      slug: course.slug,
    };
  })
);
---

<Layout metadata={metadata}>
  <Features2
    title="Our Magickal Courses"
    subtitle="Learn at your own pace with our structured modules and expert guidance."
    items={items}
  />

  <!-- Hidden data store for lesson counts -->
  {items.map((item) => <div class="hidden course-data" data-slug={item.slug} data-total={item.lessonCount} />)}

  <script>
    import { getCompletedLessons, calculateProgress } from '~/utils/progress';

    function updateAllCourseProgress() {
      const dataStores = document.querySelectorAll('.course-data');

      dataStores.forEach((store) => {
        const slug = (store as HTMLElement).dataset.slug;
        const total = parseInt((store as HTMLElement).dataset.total || '0');

        if (!slug || total === 0) return;

        const completed = getCompletedLessons(slug);
        const percent = calculateProgress(completed.length, total);

        // Find the card for this course
        const card = document.querySelector(`.course-card-${slug}`);
        if (card) {
          // Check if we already added a progress indicator
          let progressInfo = card.querySelector('.course-progress-info');
          if (!progressInfo) {
            progressInfo = document.createElement('div');
            progressInfo.className =
              'course-progress-info mt-4 pt-4 border-t border-slate-100 dark:border-slate-800 w-full';
            card.appendChild(progressInfo);
          }

          if (completed.length > 0) {
            progressInfo.innerHTML = `
              <div class="flex items-center justify-between mb-1">
                <span class="text-xs font-bold text-muted uppercase tracking-wider">Progress</span>
                <span class="text-xs font-bold text-primary">${percent}%</span>
              </div>
              <div class="w-full bg-slate-100 dark:bg-slate-800 rounded-full h-2 overflow-hidden">
                <div class="bg-primary h-full transition-all duration-500" style="width: ${percent}%"></div>
              </div>
            `;
          } else {
            progressInfo.innerHTML = '';
          }
        }
      });
    }

    // Run on load and on transitions
    document.addEventListener('DOMContentLoaded', updateAllCourseProgress);
    document.addEventListener('astro:page-load', updateAllCourseProgress);

    // Update on Identity events
    const netlifyIdentity = (window as any).netlifyIdentity;
    if (netlifyIdentity) {
      netlifyIdentity.on('init', updateAllCourseProgress);
      netlifyIdentity.on('login', updateAllCourseProgress);
      netlifyIdentity.on('logout', updateAllCourseProgress);
    }
  </script>
</Layout>
