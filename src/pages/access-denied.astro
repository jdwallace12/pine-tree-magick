---
import Layout from "~/layouts/PageLayout.astro";
import { Icon } from "astro-icon/components";

const metadata = {
  title: "Access Denied",
  robots: {
    index: false,
    follow: false,
  },
  // Prevent caching of this page to ensure redirect logic stays fresh
  meta: [
    { name: "pragma", content: "no-cache" },
    { name: "cache-control", content: "no-cache, no-store, must-revalidate" },
  ],
};
---

<Layout metadata={metadata}>
  <div
    class="max-w-4xl mx-auto px-4 py-20 flex flex-col items-center justify-center min-h-[60vh]"
  >
    <div
      class="text-center bg-slate-50 dark:bg-slate-800 p-12 rounded-3xl border-2 border-dashed border-slate-200 dark:border-slate-700 w-full max-w-2xl"
    >
      <div
        class="w-24 h-24 mx-auto mb-8 rounded-full bg-slate-100 dark:bg-slate-800 border-2 border-slate-200 dark:border-slate-700 flex items-center justify-center text-slate-400 dark:text-slate-500"
      >
        <Icon name="tabler:lock" class="w-12 h-12" />
      </div>

      <h1 class="text-4xl font-heading font-bold mb-6">Members Only Content</h1>

      <p class="text-lg text-muted mb-10 max-w-md mx-auto leading-relaxed">
        This premium content is restricted. Please sign in to verify your access
        or enroll in the course to unlock these materials.
      </p>

      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a
          id="access-login-link"
          href="javascript:void(0)"
          onclick="window.dispatchEvent(new CustomEvent('open-auth-modal', { detail: { view: 'login' } }))"
          class="bg-primary text-white px-8 py-4 rounded-full font-bold transition-transform hover:scale-105 shadow-lg flex items-center justify-center"
        >
          <Icon name="tabler:login" class="w-5 h-5 mr-2" />
          Sign In to Access
        </a>
        <a
          href="/shop#courses"
          class="bg-white dark:bg-slate-900 text-slate-900 dark:text-white border border-slate-200 dark:border-slate-700 px-8 py-4 rounded-full font-bold transition-all hover:bg-slate-50 dark:hover:bg-slate-800 hover:border-slate-300 flex items-center justify-center"
        >
          <Icon name="tabler:shopping-cart" class="w-5 h-5 mr-2" />
          Enroll
        </a>
      </div>

      <!-- Dev Spoof (Visible only on localhost) -->
      <div id="dev-spoof-container" class="mt-16 hidden">
        <div
          class="inline-block bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 p-4 rounded-xl"
        >
          <p
            class="text-xs text-amber-800 dark:text-amber-500 mb-3 uppercase tracking-widest font-bold"
          >
            Developer Tools
          </p>
          <div class="flex gap-2 justify-center">
            <button
              id="dev-spoof-magickal"
              class="bg-amber-100 dark:bg-amber-800/50 text-amber-900 dark:text-amber-300 border border-amber-200 dark:border-amber-700 px-4 py-2 rounded-lg text-sm font-medium hover:bg-amber-200 dark:hover:bg-amber-700/80 transition"
            >
              Spoof Magickal Access
            </button>
            <button
              id="dev-spoof-chakra"
              class="bg-amber-100 dark:bg-amber-800/50 text-amber-900 dark:text-amber-300 border border-amber-200 dark:border-amber-700 px-4 py-2 rounded-lg text-sm font-medium hover:bg-amber-200 dark:hover:bg-amber-700/80 transition"
            >
              Spoof Chakra Access
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    document.addEventListener("astro:page-load", function () {
      if (!window.netlifyIdentity) return;

      // Extract course slug from returnTo, e.g. /courses/magickal-foundations/lesson → magickal-foundations
      function getCourseSlugFromReturnTo() {
        var params = new URLSearchParams(window.location.search);
        var returnTo = params.get("returnTo") || "";
        var match = returnTo.match(/^\/courses\/([^\/]+)\//);
        return match ? match[1] : null;
      }

      function decodeJwt(token) {
        try {
          if (!token || typeof token !== "string") return null;
          var base64Url = token.split(".")[1];
          if (!base64Url) return null;
          var base64 = base64Url.replace(/-/g, "+").replace(/_/g, "/");
          while (base64.length % 4) base64 += "=";
          return JSON.parse(atob(base64));
        } catch (e) {
          return { error: e.message };
        }
      }

      function hardReset() {
        if (
          confirm(
            "This will log you out and clear all course-related session data. Proceed?",
          )
        ) {
          window.netlifyIdentity.logout();
          document.cookie = "nf_jwt=; path=/; max-age=0; SameSite=Lax";
          sessionStorage.clear();
          localStorage.removeItem("gotrue.user");
          location.href = "/";
        }
      }

      // Main: refresh token, check role, redirect only if authorized
      function tryRedirect() {
        var user = window.netlifyIdentity.currentUser();
        if (!user) return;

        var guardKey = "access_denied_redirect_guard";
        var isLooping = !!sessionStorage.getItem(guardKey);

        var courseSlug = getCourseSlugFromReturnTo();
        var requiredRole = courseSlug ? "course:" + courseSlug : null;
        var buildTime = "2026-02-23_21:40";

        user
          .jwt(true)
          .then(function (token) {
            var tokenLen = token ? token.length : 0;
            if (token) {
              // TEST A: Simple name-value (no attributes)
              document.cookie = "nf_jwt_a=" + token;

              // TEST B: With path
              document.cookie = "nf_jwt_b=" + token + "; path=/";

              // TARGET: Traditional
              document.cookie =
                "nf_jwt=" + token + "; path=/; max-age=3600; SameSite=Lax";

              // DIAGNOSTIC
              document.cookie = "diag_test=1; path=/; max-age=60";
            }

            var claims = decodeJwt(token);
            var roles = (user.app_metadata && user.app_metadata.roles) || [];
            var jwtRoles =
              (claims && claims.app_metadata && claims.app_metadata.roles) ||
              [];

            // Diagnose Cookie State
            var c = document.cookie;
            var results = {
              nf_jwt: c.indexOf("nf_jwt=") !== -1,
              nf_jwt_a: c.indexOf("nf_jwt_a=") !== -1,
              nf_jwt_b: c.indexOf("nf_jwt_b=") !== -1,
              diag: c.indexOf("diag_test=") !== -1,
              len: tokenLen,
            };

            console.log("=== Access Denied v" + buildTime + " ===");
            console.log("Cookie Results:", results);

            if (isLooping) {
              sessionStorage.removeItem(guardKey);
              showLoggedInMessage(user, "CDN_BLOCK", {
                required: requiredRole,
                appRoles: roles,
                jwtRoles: jwtRoles,
                tokenPresent: !!token,
                results: results,
              });
              return;
            }

            if (
              requiredRole &&
              roles.indexOf(requiredRole) === -1 &&
              jwtRoles.indexOf(requiredRole) === -1
            ) {
              showLoggedInMessage(user, "MISSING_ROLE", {
                required: requiredRole,
                roles: roles,
              });
              return;
            }

            // User HAS the role — redirect
            sessionStorage.setItem(guardKey, "1");
            var params = new URLSearchParams(window.location.search);
            var returnTo = params.get("returnTo");
            if (returnTo && returnTo.startsWith("/")) {
              window.location.href = returnTo;
            } else {
              window.location.href = "/shop#courses";
            }
          })
          .catch(function (err) {
            showLoggedInMessage(user, "JWT_ERROR", { message: err.message });
          });
      }

      function showLoggedInMessage(user, type, data) {
        var title = document.querySelector("h1");
        var desc = document.querySelector(".text-lg.text-muted");
        var loginLink = document.getElementById("access-login-link");

        if (title)
          title.textContent =
            type === "CDN_BLOCK"
              ? "Access authorized, but CDN is blocking"
              : "You Don't Have Access Yet";

        if (desc) {
          var msg =
            "<p class='mb-4'>Signed in as <strong>" +
            user.email +
            "</strong></p>";
          if (type === "CDN_BLOCK") {
            var res = data.results || {};
            msg +=
              "<div class='text-sm text-slate-600 mb-4 font-sans bg-amber-50 p-4 rounded-lg border border-amber-200'>" +
              "<strong>Cookie Persistence Tests:</strong><ul class='list-disc ml-5 mt-2'>" +
              "<li>Netlify Standard (nf_jwt): " +
              (res.nf_jwt ? "✅" : "❌") +
              "</li>" +
              "<li>Raw Token (No Attributes): " +
              (res.nf_jwt_a ? "✅" : "❌") +
              "</li>" +
              "<li>Token with Path: " +
              (res.nf_jwt_b ? "✅" : "❌") +
              "</li>" +
              "<li>Test Cookie (Small): " +
              (res.diag ? "✅" : "❌") +
              "</li>" +
              "</ul><p class='mt-2 font-bold'>Token Length: " +
              res.len +
              " characters</p></div>";
          }
          desc.innerHTML = msg;
        }

        if (loginLink) {
          loginLink.textContent = "Hard Reset Session";
          loginLink.href = "javascript:hardReset()";
          loginLink.style.display = "flex";
          loginLink.classList.remove("bg-primary");
          loginLink.style.backgroundColor = "#ef4444";
        }

        if (type === "CDN_BLOCK") {
          var enterBtn = document.createElement("a");
          enterBtn.textContent = "Retry Access";
          enterBtn.href = "javascript:location.reload()";
          enterBtn.style.cssText =
            "margin-top:1rem;background:#10b981;color:white;padding:1rem 2rem;border-radius:9999px;font-weight:bold;display:flex;align-items:center;justify-content:center;transition:transform 0.2s;";
          var container =
            document.querySelector(".flex-col.sm\\:flex-row") ||
            document.querySelector(".flex.flex-col");
          if (container && !document.getElementById("force-enter")) {
            enterBtn.id = "force-enter";
            container.appendChild(enterBtn);
          }
        }
      }

      // Check immediately — the Identity widget init has already fired
      var existingUser = window.netlifyIdentity.currentUser();
      if (existingUser) {
        tryRedirect();
        return;
      }

      // Fallback: in case init hasn't fired yet
      window.netlifyIdentity.on("init", function () {
        if (window.netlifyIdentity.currentUser()) {
          tryRedirect();
        }
      });

      // If the user signs in FROM this page
      window.netlifyIdentity.on("login", function () {
        tryRedirect();
      });

      // Dev Spoof Logic
      const spoofContainer = document.getElementById("dev-spoof-container");
      const isLocal =
        window.location.hostname === "localhost" ||
        window.location.hostname === "127.0.0.1";

      if (isLocal && spoofContainer) {
        spoofContainer.classList.remove("hidden");

        document
          .getElementById("dev-spoof-magickal")
          ?.addEventListener("click", () => {
            sessionStorage.setItem("spoof_course:magickal-foundations", "true");
            alert(
              "Spoofed access to Magickal Foundations. You can now navigate back to the lesson.",
            );
          });

        document
          .getElementById("dev-spoof-chakra")
          ?.addEventListener("click", () => {
            sessionStorage.setItem("spoof_course:chakra-mastery", "true");
            alert(
              "Spoofed access to Chakra Mastery. You can now navigate back to the lesson.",
            );
          });
      }
    });
  </script>
</Layout>
