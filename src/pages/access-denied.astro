---
import Layout from "~/layouts/PageLayout.astro";
import { Icon } from "astro-icon/components";

const metadata = {
  title: "Access Denied",
  robots: {
    index: false,
    follow: false,
  },
};
---

<Layout metadata={metadata}>
  <div
    class="max-w-4xl mx-auto px-4 py-20 flex flex-col items-center justify-center min-h-[60vh]"
  >
    <div
      class="text-center bg-slate-50 dark:bg-slate-800 p-12 rounded-3xl border-2 border-dashed border-slate-200 dark:border-slate-700 w-full max-w-2xl"
    >
      <div
        class="w-24 h-24 mx-auto mb-8 rounded-full bg-slate-100 dark:bg-slate-800 border-2 border-slate-200 dark:border-slate-700 flex items-center justify-center text-slate-400 dark:text-slate-500"
      >
        <Icon name="tabler:lock" class="w-12 h-12" />
      </div>

      <h1 class="text-4xl font-heading font-bold mb-6">Members Only Content</h1>

      <p class="text-lg text-muted mb-10 max-w-md mx-auto leading-relaxed">
        This premium content is restricted. Please sign in to verify your access
        or enroll in the course to unlock these materials.
      </p>

      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a
          id="access-login-link"
          href="javascript:void(0)"
          onclick="window.dispatchEvent(new CustomEvent('open-auth-modal', { detail: { view: 'login' } }))"
          class="bg-primary text-white px-8 py-4 rounded-full font-bold transition-transform hover:scale-105 shadow-lg flex items-center justify-center"
        >
          <Icon name="tabler:login" class="w-5 h-5 mr-2" />
          Sign In to Access
        </a>
        <a
          href="/shop#courses"
          class="bg-white dark:bg-slate-900 text-slate-900 dark:text-white border border-slate-200 dark:border-slate-700 px-8 py-4 rounded-full font-bold transition-all hover:bg-slate-50 dark:hover:bg-slate-800 hover:border-slate-300 flex items-center justify-center"
        >
          <Icon name="tabler:shopping-cart" class="w-5 h-5 mr-2" />
          Enroll
        </a>
      </div>

      <!-- Dev Spoof (Visible only on localhost) -->
      <div id="dev-spoof-container" class="mt-16 hidden">
        <div
          class="inline-block bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 p-4 rounded-xl"
        >
          <p
            class="text-xs text-amber-800 dark:text-amber-500 mb-3 uppercase tracking-widest font-bold"
          >
            Developer Tools
          </p>
          <div class="flex gap-2 justify-center">
            <button
              id="dev-spoof-magickal"
              class="bg-amber-100 dark:bg-amber-800/50 text-amber-900 dark:text-amber-300 border border-amber-200 dark:border-amber-700 px-4 py-2 rounded-lg text-sm font-medium hover:bg-amber-200 dark:hover:bg-amber-700/80 transition"
            >
              Spoof Magickal Access
            </button>
            <button
              id="dev-spoof-chakra"
              class="bg-amber-100 dark:bg-amber-800/50 text-amber-900 dark:text-amber-300 border border-amber-200 dark:border-amber-700 px-4 py-2 rounded-lg text-sm font-medium hover:bg-amber-200 dark:hover:bg-amber-700/80 transition"
            >
              Spoof Chakra Access
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    document.addEventListener("astro:page-load", function () {
      if (!window.netlifyIdentity) return;

      // Extract course slug from returnTo, e.g. /courses/magickal-foundations/lesson → magickal-foundations
      function getCourseSlugFromReturnTo() {
        var params = new URLSearchParams(window.location.search);
        var returnTo = params.get("returnTo") || "";
        var match = returnTo.match(/^\/courses\/([^\/]+)\//);
        return match ? match[1] : null;
      }

      // Decode a JWT payload (base64url) without a library
      function decodeJwtPayload(token) {
        try {
          if (!token || typeof token !== "string")
            return { error: "Token is not a string: " + typeof token };
          var parts = token.split(".");
          if (parts.length < 2)
            return { error: "Token has only " + parts.length + " parts" };

          var payloadBase64 = parts[1].replace(/-/g, "+").replace(/_/g, "/");
          while (payloadBase64.length % 4) payloadBase64 += "=";

          var decodedStr;
          try {
            // Standard atob
            decodedStr = atob(payloadBase64);
          } catch (atobErr) {
            return {
              error: "atob failed: " + atobErr.message,
              rawLength: payloadBase64.length,
            };
          }

          try {
            // Handle UTF-8 correctly
            var finalStr = decodeURIComponent(escape(decodedStr));
            return JSON.parse(finalStr);
          } catch (parseErr) {
            // Fallback to simple JSON parse if decodeURIComponent fails
            try {
              return JSON.parse(decodedStr);
            } catch (jsonErr) {
              return {
                error: "JSON parse failed: " + jsonErr.message,
                raw: decodedStr.substring(0, 50) + "...",
              };
            }
          }
        } catch (globalErr) {
          return { error: "Global decoding error: " + globalErr.message };
        }
      }

      // Main: refresh token, check role, redirect only if authorized
      function tryRedirect() {
        var user = window.netlifyIdentity.currentUser();
        if (!user) return;

        // Guard against redirect loops — only attempt once per page load
        var guardKey = "access_denied_redirect_guard";
        if (sessionStorage.getItem(guardKey)) {
          sessionStorage.removeItem(guardKey);
          showLoggedInMessage(user);
          return;
        }

        var courseSlug = getCourseSlugFromReturnTo();
        var requiredRole = courseSlug ? "course:" + courseSlug : null;

        // DEBUG: version to verify build
        console.log("Access Denied Script Version: 2026-02-23_20:50");

        user.jwt(true).then(function (token) {
          if (!token) {
            showLoggedInMessage(user, {
              error: "No token returned from user.jwt(true)",
            });
            return;
          }

          // Check if the JWT actually contains the required role
          var claims = decodeJwtPayload(token) || {
            error: "decodeJwtPayload returned null",
          };
          var roles =
            (claims && claims.app_metadata && claims.app_metadata.roles) || [];

          // DEBUG: log JWT claims to diagnose role format
          console.log("=== ACCESS DENIED DEBUG ===");
          console.log("Required role:", requiredRole);
          console.log("Roles found in JWT:", roles);
          console.log(
            "Full app_metadata:",
            JSON.stringify(claims && claims.app_metadata),
          );
          console.log("Full JWT claims:", JSON.stringify(claims));

          if (requiredRole && roles.indexOf(requiredRole) === -1) {
            // User is logged in but does NOT have the role — show helpful message
            showLoggedInMessage(user, claims);
            return;
          }

          // User HAS the role — set cookie and redirect
          document.cookie =
            "nf_jwt=" + token + "; path=/; max-age=3600; SameSite=Lax";
          sessionStorage.setItem(guardKey, "1");
          var params = new URLSearchParams(window.location.search);
          var returnTo = params.get("returnTo");
          if (returnTo && returnTo.startsWith("/")) {
            window.location.href = returnTo;
          } else {
            window.location.href = "/shop#courses";
          }
        });
      }

      // Update the UI to show the user is signed in but lacks access
      function showLoggedInMessage(user, claims) {
        var title = document.querySelector("h1");
        var desc = document.querySelector(".text-lg.text-muted");
        var loginLink = document.getElementById("access-login-link");
        if (title) title.textContent = "You Don\u2019t Have Access Yet";
        if (desc) {
          desc.textContent =
            "You\u2019re signed in as " +
            (user.email || "a registered user") +
            ", but your account doesn\u2019t have access to this course. " +
            "Please enroll to unlock this content.";
        }
        if (loginLink) loginLink.style.display = "none";

        // DEBUG: show JWT claims on page (remove after debugging)
        var debugContainer =
          document.querySelector(".text-center") || document.body;
        if (debugContainer) {
          // Remove any existing debug panels first
          var existingDebug = document.getElementById("access-debug-panel");
          if (existingDebug) existingDebug.remove();

          var debugEl = document.createElement("div");
          debugEl.id = "access-debug-panel";
          debugEl.style.cssText =
            "margin-top:2rem;padding:1.5rem;background:#0f172a;border:2px solid #f59e0b;border-radius:12px;text-align:left;font-size:12px;color:#f59e0b;max-width:640px;margin-left:auto;margin-right:auto;overflow-x:auto;box-shadow:0 10px 15px -3px rgba(0,0,0,0.1);";

          var buildVersion = "2026-02-23_20:50";
          var userRoles = (user.app_metadata && user.app_metadata.roles) || [];

          var claimsHtml = claims
            ? "<pre style='color:#94a3b8;margin-top:0.5rem;white-space:pre-wrap;word-break:break-all;'>" +
              JSON.stringify(claims, null, 2) +
              "</pre>"
            : "<p style='color:#ef4444;'>Error: No claims found (JWT decoding failed). Check console for details.</p>";

          debugEl.innerHTML =
            "<div style='margin-bottom:0.5rem;display:flex;justify-content:space-between;'>" +
            "<strong>\u26a0\ufe0f ACCESS DENIED DEBUG</strong>" +
            "<span style='color:#64748b;font-family:monospace;'>Build: " +
            buildVersion +
            "</span>" +
            "</div>" +
            "<div style='margin-bottom:1rem;color:#94a3b8;'>Client-side roles: " +
            JSON.stringify(userRoles) +
            "</div>" +
            "<strong>JWT Claims (from Identity):</strong>" +
            claimsHtml;
          debugContainer.appendChild(debugEl);
        }
      }

      // Check immediately — the Identity widget init has already fired
      var existingUser = window.netlifyIdentity.currentUser();
      if (existingUser) {
        tryRedirect();
        return;
      }

      // Fallback: in case init hasn't fired yet
      window.netlifyIdentity.on("init", function () {
        if (window.netlifyIdentity.currentUser()) {
          tryRedirect();
        }
      });

      // If the user signs in FROM this page
      window.netlifyIdentity.on("login", function () {
        tryRedirect();
      });

      // Dev Spoof Logic
      const spoofContainer = document.getElementById("dev-spoof-container");
      const isLocal =
        window.location.hostname === "localhost" ||
        window.location.hostname === "127.0.0.1";

      if (isLocal && spoofContainer) {
        spoofContainer.classList.remove("hidden");

        document
          .getElementById("dev-spoof-magickal")
          ?.addEventListener("click", () => {
            sessionStorage.setItem("spoof_course:magickal-foundations", "true");
            alert(
              "Spoofed access to Magickal Foundations. You can now navigate back to the lesson.",
            );
          });

        document
          .getElementById("dev-spoof-chakra")
          ?.addEventListener("click", () => {
            sessionStorage.setItem("spoof_course:chakra-mastery", "true");
            alert(
              "Spoofed access to Chakra Mastery. You can now navigate back to the lesson.",
            );
          });
      }
    });
  </script>
</Layout>
