---
import Layout from '~/layouts/PageLayout.astro';
import Quiz, { type Question } from '~/components/widgets/Quiz.astro';

const metadata = {
  title: 'Quiz Component Demo',
  description: 'A demonstration of the interactive Quiz component',
};

// Example quiz data that can be dynamically loaded from a CMS or JSON file
const quizQuestions: Question[] = [
  {
    id: 'q1',
    type: 'image-row',
    question: 'Which element is most associated with the suit of Cups in Tarot?',
    options: [
      {
        text: 'Fire',
        image:
          'https://images.unsplash.com/photo-1542272201-b1ca555f8505?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80',
      },
      {
        text: 'Earth',
        image:
          'https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80',
      },
      {
        text: 'Air',
        image:
          'https://images.unsplash.com/photo-1500382017468-9049fed747ef?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80',
      },
      {
        text: 'Water',
        image:
          'https://images.unsplash.com/photo-1518837695005-2083093ee35b?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80',
      },
    ],
    answer: 'Water',
  },
  {
    id: 'q2',
    type: 'reveal-row',
    question: 'Use your intuition: which card is the Mountain?',
    options: [
      {
        text: 'Forest',
        image: 'https://images.unsplash.com/photo-1441974231531-c6227db76b6e?q=80&w=800&auto=format&fit=crop',
      },
      {
        text: 'Ocean',
        image: 'https://images.unsplash.com/photo-1507525428034-b723cf961d3e?q=80&w=800&auto=format&fit=crop',
      },
      {
        text: 'Mountain',
        image: 'https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?q=80&w=800&auto=format&fit=crop',
      },
      {
        text: 'Desert',
        image: 'https://images.unsplash.com/photo-1473580044384-7ba9967e16a0?q=80&w=800&auto=format&fit=crop',
      },
    ],
    answer: 'Mountain',
  },
  {
    id: 'q3',
    type: 'image-row',
    question: 'Choose your favorite element of nature:',
    options: [
      {
        text: 'Forest',
        image: 'https://images.unsplash.com/photo-1441974231531-c6227db76b6e?q=80&w=800&auto=format&fit=crop',
      },
      {
        text: 'Ocean',
        image: 'https://images.unsplash.com/photo-1507525428034-b723cf961d3e?q=80&w=800&auto=format&fit=crop',
      },
      {
        text: 'Mountain',
        image: 'https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?q=80&w=800&auto=format&fit=crop',
      },
      {
        text: 'Desert',
        image: 'https://images.unsplash.com/photo-1473580044384-7ba9967e16a0?q=80&w=800&auto=format&fit=crop',
      },
    ],
    answer: 'Forest',
  },
  {
    id: 'q4',
    type: 'multiple-choice',
    question: 'How many phases in the lunar cycle?',
    options: ['4', '6', '8', '12'],
    answer: '8',
  },
  {
    id: 'q5',
    type: 'text',
    question: 'Which astrological sign is represented by the twins?',
    answer: 'Gemini',
  },
];
---

<Layout metadata={metadata}>
  <section class="min-h-screen py-16 px-4 sm:px-6 lg:px-8 bg-slate-50 dark:bg-slate-900">
    <div class="max-w-4xl mx-auto mb-12 text-center">
      <h1 class="text-4xl md:text-5xl font-bold font-heading mb-4 dark:text-white">Quiz Component Demonstration</h1>
      <p class="text-xl text-slate-600 dark:text-slate-400">
        Test this interactive Vanilla JS quiz component populated with JSON.
      </p>
    </div>

    <!-- Integrate the Quiz Component -->
    <Quiz title="Cosmic Knowledge Test" questions={quizQuestions} />

    <div
      class="max-w-3xl mx-auto mt-12 bg-white dark:bg-slate-800 p-6 rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm"
    >
      <h3 class="text-xl font-bold mb-4 dark:text-white">How it works</h3>
      <p class="text-slate-600 dark:text-slate-300 mb-4">
        The <code>&lt;Quiz /&gt;</code> component takes a <code>questions</code> prop, which is an array of objects. It supports
        both <strong>multiple-choice</strong> and <strong>text</strong> (fill-in-the-blank) question types.
      </p>
      <p class="text-slate-600 dark:text-slate-300 mb-4">
        The logic handles state management purely via a client-side Astro script tag, requiring zero UI framework
        overhead.
      </p>
      <pre
        class="bg-slate-100 dark:bg-slate-900 p-4 rounded-lg overflow-x-auto text-sm text-slate-800 dark:text-slate-200">
<code>&lt;Quiz 
  title="Cosmic Knowledge Test" 
  questions={[
    {
      id: "q1",
      type: "multiple-choice",
      question: "Which planet is known as the Red Planet?",
      options: ["Venus", "Mars", "Jupiter", "Saturn"],
      answer: "Mars"
    }
  ]} 
/&gt;</code>
      </pre>
    </div>
  </section>
</Layout>
