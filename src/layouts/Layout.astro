---
import '~/assets/styles/tailwind.css';

import { I18N } from 'astrowind:config';

import CommonMeta from '~/components/common/CommonMeta.astro';
import Favicons from '~/components/Favicons.astro';
import CustomStyles from '~/components/CustomStyles.astro';
import ApplyColorMode from '~/components/common/ApplyColorMode.astro';
import Metadata from '~/components/common/Metadata.astro';
import SiteVerification from '~/components/common/SiteVerification.astro';
import Analytics from '~/components/common/Analytics.astro';
import BasicScripts from '~/components/common/BasicScripts.astro';

// Comment the line below to disable View Transitions
import { ViewTransitions } from 'astro:transitions';

import type { MetaData as MetaDataType } from '~/types';

export interface Props {
  metadata?: MetaDataType;
}

const { metadata = {} } = Astro.props;
const { language, textDirection } = I18N;
---

<!doctype html>
<html lang={language} dir={textDirection} class="2xl:text-[20px]">
  <head>
    <CommonMeta />
    <Favicons />
    <CustomStyles />
    <ApplyColorMode />
    <Metadata {...metadata} />
    <SiteVerification />
    <Analytics />

    <!-- Comment the line below to disable View Transitions -->
    <ViewTransitions fallback="swap" />
  </head>

  <body class="antialiased text-default bg-page tracking-tight">
    <slot />

    <BasicScripts />

    <!-- Netlify Identity widget -->
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js" is:inline></script>
    <script is:inline>
      (function () {
        // Idempotent initialization tracker
        window.__identityInitialized = window.__identityInitialized || false;

        function initIdentity() {
          if (!window.netlifyIdentity) return;

          const isLocal = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1';

          // 1. Force Local Proxy on Localhost
          if (isLocal) {
            try {
              // Clear cached production URL to force proxy use
              if (localStorage.getItem('netlifySiteURL')) {
                console.log('🧹 Clearing cached Netlify Site URL for localhost...');
                localStorage.removeItem('netlifySiteURL');
              }
            } catch (e) {}
          }

          // 2. Setup Global Listeners (only once)
          if (!window.__identityListenersAdded) {
            const globalUpdate = () => {
              const accBtn = document.getElementById('account-button');
              if (accBtn) {
                const user = window.netlifyIdentity.currentUser();
                accBtn.textContent = user ? user.user_metadata?.full_name || 'My Account' : 'Account';
              }
            };

            window.netlifyIdentity.on('init', globalUpdate);
            window.netlifyIdentity.on('login', () => {
              globalUpdate();
              window.netlifyIdentity.close();
            });
            window.netlifyIdentity.on('logout', globalUpdate);

            window.__identityListenersAdded = true;
          }

          // 3. Initialize the widget (only once)
          if (!window.__identityInitialized) {
            window.netlifyIdentity.init({
              API_URL: isLocal ? '/.netlify/identity' : undefined,
            });
            window.__identityInitialized = true;
          }

          // 4. Setup Account Button (Page specific)
          const btn = document.getElementById('account-button');
          if (btn && !btn.dataset.identityReady) {
            btn.dataset.identityReady = 'true';
            btn.addEventListener('click', () => {
              window.netlifyIdentity.open();
            });

            // Sync text immediately on page load
            const user = window.netlifyIdentity.currentUser();
            btn.textContent = user ? user.user_metadata?.full_name || 'My Account' : 'Account';
          }
        }

        // Initialize on DOM ready and after every Astro View Transition
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initIdentity);
        } else {
          initIdentity();
        }
        document.addEventListener('astro:page-load', initIdentity);
      })();
    </script>
  </body>
</html>
