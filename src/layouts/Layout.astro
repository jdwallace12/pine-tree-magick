---
import "~/assets/styles/tailwind.css";

import { I18N } from "astrowind:config";

import CommonMeta from "~/components/common/CommonMeta.astro";
import Favicons from "~/components/Favicons.astro";
import CustomStyles from "~/components/CustomStyles.astro";
import ApplyColorMode from "~/components/common/ApplyColorMode.astro";
import Metadata from "~/components/common/Metadata.astro";
import SiteVerification from "~/components/common/SiteVerification.astro";
import Analytics from "~/components/common/Analytics.astro";
import BasicScripts from "~/components/common/BasicScripts.astro";
import AuthModal from "~/components/common/AuthModal.astro";

// Comment the line below to disable View Transitions
import { ViewTransitions } from "astro:transitions";

import type { MetaData as MetaDataType } from "~/types";

export interface Props {
  metadata?: MetaDataType;
}

const { metadata = {} } = Astro.props;
const { language, textDirection } = I18N;
---

<!doctype html>
<html lang={language} dir={textDirection} class="2xl:text-[20px]">
  <head>
    <CommonMeta />
    <Favicons />
    <CustomStyles />
    <ApplyColorMode />
    <Metadata {...metadata} />
    <SiteVerification />
    <Analytics />

    <!-- Comment the line below to disable View Transitions -->
    <ViewTransitions fallback="swap" />

    <!-- Netlify Identity widget -->
    <script
      src="https://identity.netlify.com/v1/netlify-identity-widget.js"
      is:inline></script>
    <script is:inline>
      (function () {
        // Ultra-defensive initialization
        window.__identityInitialized = window.__identityInitialized || false;
        window.__identityListenersAdded =
          window.__identityListenersAdded || false;

        function initIdentity() {
          if (!window.netlifyIdentity) return;

          const isLocal =
            window.location.hostname === "localhost" ||
            window.location.hostname === "127.0.0.1";

          // 1. Force Local Proxy on Localhost
          if (isLocal) {
            try {
              if (localStorage.getItem("netlifySiteURL")) {
                localStorage.removeItem("netlifySiteURL");
              }
            } catch (e) {}
          }

          // 2. Setup Global Listeners (once)
          if (!window.__identityListenersAdded) {
            // Keep the nf_jwt cookie fresh — Netlify's CDN edge checks this
            // cookie for role-based redirects BEFORE any JS runs.
            function refreshJwtCookie() {
              var user = window.netlifyIdentity.currentUser();
              if (!user) return;
              // user.jwt() force-refreshes the token — user.token.access_token
              // may be stale/expired, and Netlify's CDN ignores expired JWTs.
              user.jwt().then(function (token) {
                if (token) {
                  document.cookie =
                    "nf_jwt=" + token + "; path=/; max-age=3600; SameSite=Lax";
                }
              });
            }

            function clearJwtCookie() {
              document.cookie = "nf_jwt=; path=/; max-age=0; SameSite=Lax";
            }

            const globalUpdate = () => {
              const accBtn = document.getElementById("account-button");
              if (accBtn) {
                const user = window.netlifyIdentity.currentUser();
                accBtn.innerHTML = `<span>${user ? user.user_metadata?.full_name || "My Account" : "Account"}</span>`;
              }
            };

            window.netlifyIdentity.on("init", () => {
              globalUpdate();
              refreshJwtCookie();
            });
            window.netlifyIdentity.on("login", () => {
              globalUpdate();
              refreshJwtCookie();
              window.netlifyIdentity.close();
            });
            window.netlifyIdentity.on("logout", () => {
              globalUpdate();
              clearJwtCookie();
            });
            window.__identityListenersAdded = true;
          }

          // 3. Initialize widget (once)
          if (!window.__identityInitialized) {
            window.netlifyIdentity.init({
              API_URL: isLocal ? "/.netlify/identity" : undefined,
            });
            window.__identityInitialized = true;
          }

          // 4. Page-specific button setup
          const btn = document.getElementById("account-button");
          if (btn && !btn.dataset.identityReady) {
            btn.dataset.identityReady = "true";
            btn.onclick = (e) => {
              const user = window.netlifyIdentity.currentUser();
              if (user) {
                window.netlifyIdentity.open(); // Open default widget for "Logout/Account" when logged in
              } else {
                window.dispatchEvent(
                  new CustomEvent("open-auth-modal", {
                    detail: { view: "login" },
                  }),
                );
              }
            };

            const user = window.netlifyIdentity.currentUser();
            btn.innerHTML = `<span>${user ? user.user_metadata?.full_name || "My Account" : "Account"}</span>`;
          }
        }

        // Run on load and on transitions
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", initIdentity);
        } else {
          initIdentity();
        }
        document.addEventListener("astro:page-load", initIdentity);
      })();
    </script>
  </head>

  <body class="antialiased text-default bg-page tracking-tight">
    <slot />

    <BasicScripts />
    <AuthModal />
  </body>
</html>
